{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "groupName": "Playwright",
      "matchPackageNames": [
        "@playwright/test",
        "@axe-core/playwright",
        "playwright",
        "playwright-core",
        "mcr.microsoft.com/playwright"
      ]
    }
  ]
}
