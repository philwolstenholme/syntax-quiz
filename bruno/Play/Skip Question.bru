meta {
  name: Skip Question
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/play/answer
  body: json
  auth: none
}

body:json {
  {
    "gameState": "{{gameState}}",
    "answer": null
  }
}

script:post-response {
  const body = res.getBody();
  if (body && body.gameState) {
    bru.setVar("gameState", body.gameState);
  }
}
