{
  "name": "syntax-quiz",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc && tsc -p netlify/tsconfig.json",
    "lint": "oxlint .",
    "preview": "vite preview",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --project=chromium --ui",
    "test:e2e:debug": "playwright test --debug",
    "knip": "knip",
    "test:e2e:headed": "playwright test --project=chromium --headed",
    "test:api": "cd bruno && bru run -r --tests-only --env Production",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@orpc/openapi": "^1.13.6",
    "@orpc/server": "^1.13.6",
    "@orpc/zod": "^1.13.6",
    "@rexa-developer/tiks": "^0.3.0",
    "@tweakpane/core": "^2.0.5",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "es-toolkit": "^1.44.0",
    "hono": "^4.12.5",
    "lucide-react": "^1.0.0",
    "motion": "^12.31.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tweakpane": "^4.0.5",
    "wouter": "^3.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@usebruno/cli": "^3.3.0",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.23",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "knip": "^6.0.0",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.6",
    "shiki": "^4.0.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "npx nano-staged"
  },
  "nano-staged": {
    "*.{js,mjs,cjs,jsx,ts,mts,cts,tsx}": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{json,jsonc,md,css,html,yaml,yml}": "oxfmt --no-error-on-unmatched-pattern"
  }
}
