meta {
  name: Submit Answer
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/play/answer
  body: json
  auth: none
}

body:json {
  {
    "gameState": "{{gameState}}",
    "answer": ""
  }
}

script:post-response {
  const body = res.getBody();
  if (body && body.gameState) {
    bru.setVar("gameState", body.gameState);
  }
}
