meta {
  name: Start Game
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/play/start
  body: json
  auth: none
}

body:json {
  {
    "level": {{level}}
  }
}

vars:pre-request {
  level: 1
}

script:post-response {
  const body = res.getBody();
  if (body && body.gameState) {
    bru.setVar("gameState", body.gameState);
  }
}
